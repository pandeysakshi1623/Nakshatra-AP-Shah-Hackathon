# ── API Base URL ──────────────────────────────────────────────
# In development, Vite proxies /api → VITE_API_URL automatically
# Only needed if you deploy frontend separately from backend
VITE_API_URL=http://localhost:4000

# ── App ───────────────────────────────────────────────────────
VITE_APP_NAME=RecoverEase
VITE_APP_VERSION=1.0.0
