# ── Server ────────────────────────────────────────────────────
PORT=4000

# ── JWT ───────────────────────────────────────────────────────
# REQUIRED — generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-key-here

# ── JWT expiry ────────────────────────────────────────────────
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Database ──────────────────────────────────────────────────
DB_PATH=./db/recoverease.json

# ── bcrypt ────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10
