# ── Server ────────────────────────────────────────────────────
PORT=4000

# ── JWT ───────────────────────────────────────────────────────
# Change this to a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=recoverease-dev-secret-change-in-production

# ── JWT expiry ────────────────────────────────────────────────
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000

# ── Database ──────────────────────────────────────────────────
# Path to the JSON flat-file database (relative to backend/)
DB_PATH=./db/recoverease.json

# ── bcrypt ────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10